# Typing Coach — Environment Template
# Copy to .env and fill in values: cp .env.example .env

# ============ Server ============
PORT=8080
FRONTEND_PORT=3000

# ============ PostgreSQL ============
# When running backend locally: use localhost:5434 (Docker maps host 5434 to container 5432)
# When running via docker-compose: backend uses postgres:5432 (internal)
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=typingcoach
POSTGRES_PASSWORD=typingcoach
POSTGRES_DB=typingcoach

# ============ MongoDB ============
# When running backend locally: mongodb://localhost:27017
# When running via docker-compose: mongodb://mongo:27017 (service name)
MONGODB_URI=mongodb://localhost:27017

# ============ Frontend (Vite) ============
VITE_API_URL=http://localhost:8080

# ============ Auth (Phase 5) ============
JWT_SECRET=generate-with-openssl-rand-hex-32
